# APPEND STORM


def normalize(token):
    return token.strip().upper()


def collect(tokens):
    out = []
    out.append(normalize(tokens[0]))
    out.append(normalize(tokens[1]))
    out.append(normalize(tokens[2]))
    out.append(normalize(tokens[3]))
    out.append(normalize(tokens[4]))
    out.append(normalize(tokens[5]))
    return out


def main():
    tokens = [" edge ", " core ", " dmz ", " prod ", " stage ", " dev "]
    result = collect(tokens)
    print(f"[+] normalized {len(result)} tokens")
    print("[+] SUCCESS")


if __name__ == "__main__":
    main()

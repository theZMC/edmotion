#!/usr/bin/env bash
# [MISE] description="Verify solution lengths match max"
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
project_root="$(cd -- "$script_dir/../../../.." && pwd)"
challenges_dir="$project_root/challenges"
failed=0
count=0

normalize_len() {
  local file="$1"
  local raw_len
  raw_len="$(wc -c < "$file" | tr -d '[:space:]')"

  if [[ "$raw_len" -eq 0 ]]; then
    echo 0
    return
  fi

  local last_byte
  last_byte="$(od -An -tx1 -N1 -j "$((raw_len - 1))" "$file" | tr -d '[:space:]')"
  if [[ "$last_byte" == "0a" ]]; then
    echo "$((raw_len - 1))"
    return
  fi

  echo "$raw_len"
}

if [[ ! -d "$challenges_dir" ]]; then
  echo "challenges directory not found: $challenges_dir" >&2
  exit 1
fi

echo "Checking solution lengths against max (single trailing newline ignored)..."
for challenge_dir in "$challenges_dir"/*; do
  [[ -d "$challenge_dir" ]] || continue

  count=$((count + 1))
  challenge_id="$(basename "$challenge_dir")"
  solution_file="$challenge_dir/solution"
  max_file="$challenge_dir/max"

  if [[ ! -f "$solution_file" || ! -f "$max_file" ]]; then
    echo "[FAIL] $challenge_id: missing solution or max file" >&2
    failed=1
    continue
  fi

  max_chars="$(tr -d '[:space:]' < "$max_file")"
  if [[ ! "$max_chars" =~ ^[0-9]+$ ]]; then
    echo "[FAIL] $challenge_id: invalid max value '$max_chars'" >&2
    failed=1
    continue
  fi

  solution_len="$(normalize_len "$solution_file")"
  if [[ "$solution_len" -ne "$max_chars" ]]; then
    echo "[FAIL] $challenge_id: solution length $solution_len does not match max $max_chars" >&2
    failed=1
  else
    echo "[OK]   $challenge_id: solution length matches max ($max_chars)"
  fi
done

if [[ "$count" -eq 0 ]]; then
  echo "No challenge directories found in $challenges_dir" >&2
  exit 1
fi

if [[ "$failed" -ne 0 ]]; then
  echo "Length verification failed" >&2
  exit 1
fi

echo "All challenge max lengths match solution lengths"
